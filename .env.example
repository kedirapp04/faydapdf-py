# ── Telegram (multi-bot) ─────────────────────────────────────────────────────
# Run 3+ bots on ONE shared DB. List every bot token, comma-separated. The bot id
# is taken from the token prefix automatically. (BOT_TOKEN still works for one.)
BOT_TOKENS=111111:AAA-token-one,222222:BBB-token-two,333333:CCC-token-three
# Optional: to spread load across processes/machines, run several copies and set
# POLL_ONLY per copy to the bot ids that copy should long-poll (blank = poll all).
# All copies keep the full BOT_TOKENS registry so notifications reach any bot.
# POLL_ONLY=111111
# Comma-separated admin Telegram ids.
ADMIN_IDS=123456789
# User-message languages, shown together in this order. "en,am" (default) = English
# then Amharic; "am" = Amharic only; "en" = English only.
MESSAGE_LANGS=en,am
# Telegram support handle shown on help/error messages (without the @). Default: faydasupport
SUPPORT_USERNAME=faydasupport

# ── Database (self-hosted Postgres on your VPS) ──────────────────────────────
# postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://fayda:secret@127.0.0.1:5432/faydapdf
DB_POOL_MIN=2
DB_POOL_MAX=12
# What to do with DOWNLOADS if Postgres is unreachable (admin-switchable at runtime):
#   refuse   = block with a "temporarily unavailable" message (default, safest)
#   free     = still deliver the PDF/screenshot, without charging or recording it
#   fallback = same as free (the full memory-replay queue isn't ported)
# Payments always refuse while the DB is down (money can't be recorded).
DB_DOWN_POLICY=refuse

# ── Fayda flow — admin can switch mode at runtime; this is the default ───────
# api      = call the fayda-railway HTTP API
# server4  = native Server 4 flow (this bot pulls its own pool token)
FAYDA_MODE_DEFAULT=api

# API mode (fayda-railway):
FAYDA_API_URL=https://fayda-railway-full-production.up.railway.app
FAYDA_API_KEY=your_fayda_railway_api_key

# Server 4 (native) mode — ntknpro token pool (fresh single-use App Check token):
SERVER4_TOKEN_API_URL=http://173.212.212.105:8010/token
SERVER4_TOKEN_API_CSRF=
SERVER4_TOKEN_MIN_SECONDS=90
# Native Server-4 endpoints (Fayda app v1.1.9). Defaults are baked in — override
# only if Fayda changes hosts. FAYDA_OTP_CHANNELS: PHONE and/or EMAIL.
# FAYDA_API_BASE=https://fayda-app-backend.fayda.et
# ESIGNET_BASE=https://auth.fayda.et
# FAYDA_BACKEND_API_KEY=
# FAYDA_OTP_CHANNELS=PHONE
# authorize-template cache (ms); saves a pool token per download. 0 = no cache.
# SERVER4_AUTHORIZE_CACHE_MS=600000
# PDF renderer (Server-4): "js" = bundled faydapdf-railway pdfGenerator via Node
# (byte-for-byte the JS output; auto-falls back to Python if Node is missing), or "py".
# FAYDA_PDF_ENGINE=js
# Optional pool-health endpoint for the admin "🎫 Tokens" view. Blank = derived
# from SERVER4_TOKEN_API_URL (last path segment → /stats).
# SERVER4_TOKEN_STATS_URL=
# Optional: Ethiopic TTF so the Amharic name renders in the PDF (else English only).
# FAYDA_AMHARIC_FONT=/opt/fonts/NotoSansEthiopic-Regular.ttf

# ── Billing ──────────────────────────────────────────────────────────────────
# Global price per download in Birr (0 = free). Stored/handled internally in cents.
GLOBAL_PRICE_BIRR=0

# ── Auto receipt verification (optional; leave blank = manual approval only) ──
# The merchant receiver (name + account) is set by the ADMIN in the UI, per bank
# (Admin panel → 💳 Payment accounts, or the web admin). Supports Telebirr AND CBE,
# is shown to users, and is what auto-verify checks a receipt was paid to.
# The two vars below are a LEGACY one-time fallback for Telebirr only if the admin
# hasn't set anything yet — normally leave them blank.
PAYMENT_RECEIVER_NAME=
PAYMENT_RECEIVER_ACCOUNT=
# Provider keys — any that are set are tried in order (verifypayment → Leul → relay).
VERIFYPAYMENT_API_KEY=
LEUL_VERIFY_API_KEY=
RELAY_VERIFY_BASE_URL=
RELAY_VERIFY_API_KEY=

# ── Web admin dashboard (run: python -m app.web) ─────────────────────────────
ADMIN_WEB_PASSWORD=change-this-password
# Random string used to sign the admin session cookie (keep secret).
WEB_SECRET=change-this-to-a-long-random-string
WEB_HOST=0.0.0.0
WEB_PORT=8080
